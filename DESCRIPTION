Package: ggbotToo
Title: Voice Assistant for R Graphics (Local)
Version: 0.0.0.9000
Authors@R:
    person("Joshua", "Goldstein", , "josh.goldstein@berkeley.edu", role = c("aut", "cre"))
Description: Interactive Shiny app that generates ggplot2 plots from voice
    commands using browser audio capture, local Whisper speech-to-text, and a
    local Ollama language model. No API keys or internet connection required.
    Inspired by 'ggbot2' by Winston Chang and Hadley Wickham.
Imports:
    audio.whisper,
    av,
    base64enc,
    bslib,
    cli,
    ellmer (>= 0.3.0),
    httr2,
    shiny,
    stats,
    tools,
    withr
Suggests:
